# Supabase Configuration
# Copy this file to .env.local and fill in your actual values

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://tsnpiggybank.com

# JPMorgan ACH sandbox OAuth
JPMORGAN_ACCESS_TOKEN_URL=https://id.payments.jpmorgan.com/am/oauth2/alpha/access_token
JPMORGAN_CLIENT_ID=your-jpmorgan-client-id
JPMORGAN_CLIENT_SECRET=your-jpmorgan-client-secret
JPMORGAN_SCOPE=jpm:payments:sandbox
